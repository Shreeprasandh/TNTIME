# ──────────────────────────────────────────────
#  TNTIME — .gitignore (Node + Java Monorepo)
# ──────────────────────────────────────────────

# ─── Java / Maven ───────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*

# ─── Node / NPM ─────────────────────────────
node_modules/
dist/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm

# ─── Vite build output ──────────────────────
frontend/dist/
frontend/.vite/

# ─── Environment / Secrets ──────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ─── IDE / Editor Configs ───────────────────
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
.DS_Store
Thumbs.db

# ─── Logs ───────────────────────────────────
logs/
*.log
spring.log

# ─── Docker ─────────────────────────────────
# (keep docker-compose.yml tracked, ignore local data volumes)
backend/postgres-data/

# ─── OS ─────────────────────────────────────
.DS_Store
ehthumbs.db
Desktop.ini
